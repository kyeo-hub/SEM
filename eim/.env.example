# ========================================
# EIM 环境变量配置
# ========================================

# ----------------------------------------
# 服务器配置
# ----------------------------------------
PORT=8080
GIN_MODE=debug

# ----------------------------------------
# 数据库配置 (PostgreSQL)
# ----------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eim
DB_SSLMODE=disable

# ----------------------------------------
# Redis 配置
# ----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DB=0

# ----------------------------------------
# JWT 配置
# ----------------------------------------
# ⚠️ 生产环境请修改为随机字符串
JWT_SECRET=
JWT_EXPIRE_HOURS=168

# ----------------------------------------
# 文件上传配置
# ----------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ----------------------------------------
# 高德地图配置 (大屏展示使用)
# ----------------------------------------
# 申请地址：https://console.amap.com/dev/index
NEXT_PUBLIC_AMAP_KEY=9fe32b42efecae60ee5cb3f269dc8f84
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# ----------------------------------------
# 企业微信机器人配置 (可选)
# ----------------------------------------
WECHAT_BOT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=aa9bc8c0-c914-473c-85fd-e9705c928ab4
WECHAT_BOT_ENABLED=true
WECHAT_BOT_DAILY_TIME=0 8 * * *

# ----------------------------------------
# Docker 端口配置
# ----------------------------------------
API_PORT=8080
WEB_PORT=3000
